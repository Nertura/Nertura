# Admin (admin.nertura.com)
# Copy to .env.local — never commit secrets

NEXT_PUBLIC_APP_URL=http://localhost:3002
NEXT_PUBLIC_APP_DOMAIN=admin.nertura.com
NEXT_PUBLIC_DASHBOARD_URL=http://localhost:3001
NEXT_PUBLIC_DASHBOARD_DOMAIN=app.nertura.com
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server only — admin operations require service role
SUPABASE_SERVICE_ROLE_KEY=

# Outreach CRM
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
RESEND_API_KEY=
OUTREACH_FROM_EMAIL=Nertura <outreach@nertura.com>
OUTREACH_NOTIFY_EMAIL=you@company.com
OUTREACH_DEFAULT_SECTOR=sera
OUTREACH_SEARCH_QUERY={sector} tarım firması iletişim e-posta Türkiye
SERPAPI_KEY=

# Cron (Vercel sends Authorization: Bearer CRON_SECRET)
CRON_SECRET=

# Optional: Cloudflare Access service token validation
CF_ACCESS_CLIENT_ID=
CF_ACCESS_CLIENT_SECRET=
