# Marketing (marketing.nertura.com)
# Copy to .env.local — never commit secrets

# Public — safe for browser
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_DOMAIN=marketing.nertura.com

# Dashboard app URL (login / register / doctor links from marketing)
# Local default: http://localhost:3001
# Production: https://app.nertura.com
NEXT_PUBLIC_DASHBOARD_URL=http://localhost:3001
NEXT_PUBLIC_DASHBOARD_DOMAIN=app.nertura.com

# Mobile LAN testing (iPhone / tablet on same Wi‑Fi):
# - Leave NEXT_PUBLIC_DASHBOARD_URL unset OR comment it out → auto-detects 192.168.x.x:3001
#   when marketing is opened at http://192.168.x.x:3000
# - Do NOT set NEXT_PUBLIC_DASHBOARD_URL=http://localhost:3001 if testing from a phone
#   (localhost on the phone is the phone itself, not your PC)
# - Optional explicit LAN override:
#   NEXT_PUBLIC_DASHBOARD_URL=http://192.168.1.102:3001

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server only
SUPABASE_SERVICE_ROLE_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# SEO
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Analytics (optional at foundation)
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# Stripe (public price IDs when configured)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
