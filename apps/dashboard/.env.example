# Dashboard (app.nertura.com)
# Copy to .env.local — never commit secrets

NEXT_PUBLIC_APP_URL=http://localhost:3001
NEXT_PUBLIC_APP_DOMAIN=app.nertura.com
NEXT_PUBLIC_MARKETING_URL=http://localhost:3000
NEXT_PUBLIC_MARKETING_DOMAIN=marketing.nertura.com
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Auth callback base — must match Supabase redirect URLs
# Production: https://app.nertura.com
# LAN mobile (iPhone): comment out NEXT_PUBLIC_APP_URL or set to http://<YOUR-LAN-IP>:3001
# Hosted Supabase → Authentication → URL Configuration → add http://<YOUR-LAN-IP>:3001/auth/callback

# Auth providers — enable in Supabase Dashboard, then set flags below
NEXT_PUBLIC_OAUTH_GOOGLE_ENABLED=false
NEXT_PUBLIC_OAUTH_APPLE_ENABLED=false
# Google OAuth setup:
# 1. Supabase Dashboard → Authentication → Providers → Google → Enable
# 2. Add Google Client ID + Secret from Google Cloud Console
# 3. Redirect URLs (Google Cloud): https://<project-ref>.supabase.co/auth/v1/callback
# 4. Supabase URL Configuration → Site URL: https://app.nertura.com
# 5. Additional redirect URLs: http://localhost:3001/**, http://<YOUR-LAN-IP>:3001/**, https://app.nertura.com/**
# 6. Set NEXT_PUBLIC_OAUTH_GOOGLE_ENABLED=true here and on Vercel
ENABLE_SMS_AUTH=false
NEXT_PUBLIC_ENABLE_SMS_AUTH=false
# When SMS is enabled later:
# REQUIRE_SMS_CAPTCHA=true
# NEXT_PUBLIC_SMS_CAPTCHA_SITE_KEY=

# Server only
SUPABASE_SERVICE_ROLE_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# AI (optional — mock mode if missing)
OPENAI_MODEL=gpt-4o-mini
GEMINI_MODEL=gemini-2.5-flash

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Email (Resend)
RESEND_API_KEY=

# Mapbox (client — farm map & geocoding)
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=
