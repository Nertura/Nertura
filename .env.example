# Nertura monorepo environment template
# Copy to .env.local at repo root for Supabase CLI / shared tooling
# App-specific vars live in apps/*/.env.example

# Mobile LAN: see docs/development/DEV_MOBILE_TESTING.md
# Do not set NEXT_PUBLIC_DASHBOARD_URL=localhost when testing from iPhone

# Supabase project (local or hosted)
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_PASSWORD=

# Supabase CLI — link to remote project
SUPABASE_PROJECT_ID=
SUPABASE_ACCESS_TOKEN=

# AI providers (server-side only — never expose to browser)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Email
RESEND_API_KEY=

# Monitoring (optional)
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
