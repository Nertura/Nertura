{
  "name": "nertura",
  "version": "0.1.0",
  "private": true,
  "description": "Nertura — AI-powered agriculture intelligence operating system",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md,json,css,mjs}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json,css,mjs}\"",
    "typecheck": "turbo run typecheck",
    "clean:next": "tsx scripts/clean-next.ts",
    "dev:mobile": "tsx scripts/dev-mobile.ts",
    "dev:mobile:marketing": "pnpm --filter @nertura/marketing dev:mobile",
    "dev:mobile:dashboard": "pnpm --filter @nertura/dashboard dev:mobile",
    "dev:mobile:admin": "pnpm --filter @nertura/admin dev:mobile",
    "dev:fresh:all": "pnpm clean:next && pnpm dev:mobile",
    "check": "pnpm check:i18n && pnpm check:css-imports",
    "test": "pnpm test:marketing-urls && pnpm test:mobile-lan-urls && pnpm test:dashboard-auth-urls",
    "supabase:start": "npx supabase start",
    "supabase:stop": "npx supabase stop",
    "supabase:reset": "npx supabase db reset",
    "supabase:push": "npx supabase db push",
    "supabase:verify": "npx supabase db execute --file supabase/scripts/verify-migrations.sql && npx supabase db execute --file supabase/scripts/verify-auth.sql",
    "supabase:verify:rls": "npx supabase db execute --file supabase/scripts/verify-rls.sql",
    "test:gemini": "tsx scripts/test-gemini.ts",
    "test:knowledge-ingestion": "tsx scripts/test-knowledge-ingestion.ts",
    "test:geo-intelligence": "tsx scripts/test-geo-intelligence.ts",
    "test:dashboard-css": "tsx scripts/test-dashboard-css.ts",
    "test:marketing-css": "tsx scripts/test-marketing-css.ts",
    "test:marketing-urls": "tsx scripts/test-marketing-urls.ts",
    "test:mobile-lan-urls": "tsx scripts/test-mobile-lan-urls.ts",
    "test:dashboard-auth-urls": "tsx scripts/test-dashboard-auth-urls.ts",
    "test:admin-css": "tsx scripts/test-admin-css.ts",
    "test:dashboard-doctor": "tsx scripts/test-dashboard-doctor.ts",
    "test:doctor-language": "tsx scripts/test-doctor-language.ts",
    "test:doctor-language-tr": "tsx scripts/test-doctor-language.ts",
    "test:dashboard-interactions": "tsx scripts/test-dashboard-interactions.ts",
    "test:projects-engine": "tsx scripts/test-projects-engine.ts",
    "test:doctor-vision-language": "tsx scripts/test-doctor-vision-language.ts",
    "test:tier-navigation": "tsx scripts/test-tier-navigation.ts",
    "test:no-legacy-chat": "tsx scripts/test-no-legacy-chat.ts",
    "test:app-css-entry": "tsx scripts/check-app-css-entry.ts",
    "check:css-imports": "tsx scripts/check-css-imports.ts",
    "check:i18n": "tsx scripts/check-hardcoded-farmer-strings.ts"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@nertura/knowledge-ingestion": "workspace:*",
    "@supabase/supabase-js": "^2.47.10",
    "dotenv": "^16.4.7",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "postcss-import": "^16.1.1",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1"
  }
}
